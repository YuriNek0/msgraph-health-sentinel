{
  "tenant_id": "<tenant-id-or-domain>",
  "client_id": "<app-client-id>",
  "client_secret": "<app-client-secret>",
  "username": "<user@tenant.com>",
  "password": "<user-password>",
  "redirect_uri": "https://localhost",
  "alert_recipient": [
    "<ops@tenant.com>",
    "<backup-ops@tenant.com>"
  ],
  "scopes": [
    "User.Read",
    "Mail.Read",
    "Mail.ReadWrite",
    "Mail.Send",
    "Files.Read",
    "Files.Read.All",
    "People.Read.All",
    "Calendars.Read",
    "Contacts.Read",
    "MailboxSettings.Read",
    "Presence.Read",
    "Team.ReadBasic.All",
    "TeamworkAppInstallation.ReadForUser",
    "Notes.Read",
    "Tasks.ReadWrite",
    "Tasks.Read.All",
    "Group.Read.All",
    "Directory.Read.All",
    "People.Read",
    "Chat.Read",
    "AuditLog.Read.All",
    "DeviceManagementConfiguration.Read.All",
    "Reports.Read.All",
    "Sites.Read.All",
    "ActivityFeed.Read",
    "User.Read.All",
    "Device.Read.All",
    "IdentityRiskyUser.Read.All",
    "SecurityEvents.Read.All",
    "DeviceManagementManagedDevices.Read.All",
    "Application.Read.All"
  ],
  "required_success_count": 6,
  "error_threshold": 3,
  "poll_delay_seconds": {
    "min": 500,
    "max": 1000
  },
  "request_timeout_seconds": 30,
  "connectivity_host": "1.1.1.1",
  "connectivity_port": 53,
  "connectivity_timeout_seconds": 5,
  "email_cooldown_minutes": 720,
  "token_refresh_window_seconds": 120
}
